<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        플래시/배지의 실제 언어별 색상은 Prefs/OverlayManager 가 ARGB Int 로 직접 관리한다.
        여기는 앱 화면(온보딩/설정) UI 의 시맨틱 팔레트 — 다크모드 값은 values-night/colors.xml.
    -->
    <!-- 칩("교체?") 배경/글씨 (bg_chip.xml, ReplaceChipView 사용) -->
    <color name="chip_bg">#1C1C1E</color>
    <color name="chip_text">#FFFFFFFF</color>

    <!-- ── 시맨틱 UI 팔레트 (라이트) ─────────────────────────────────── -->
    <!-- 화면 배경 / 카드 표면 -->
    <color name="ui_bg">#F4F6FA</color>
    <color name="ui_surface">#FFFFFF</color>
    <!-- 본문/보조 텍스트 -->
    <color name="ui_on_surface">#1A1C20</color>
    <color name="ui_on_surface_muted">#6B7280</color>
    <!-- 강조색(버튼/헤더/위젯 tint)과 그 위 텍스트 -->
    <color name="ui_accent">#2563EB</color>
    <color name="ui_on_accent">#FFFFFF</color>
    <!-- 강조 컨테이너(톤 버튼/스텝 칩 배경)와 그 위 텍스트 -->
    <color name="ui_accent_container">#E3ECFD</color>
    <color name="ui_on_accent_container">#1D4ED8</color>
    <!-- 구분선 / 보조(muted) 텍스트 별칭 -->
    <color name="ui_divider">#E5E7EB</color>
    <color name="ui_muted">#6B7280</color>

    <!-- 상태 색(완료/필요) + 필(pill) 컨테이너 -->
    <color name="status_ok">#16A34A</color>
    <color name="status_ok_container">#E4F5EA</color>
    <color name="status_need">#DC2626</color>
    <color name="status_need_container">#FCEAEA</color>
</resources>
