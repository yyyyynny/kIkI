<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        플래시/배지의 실제 언어별 색상은 Prefs/OverlayManager 가 ARGB Int 로 직접 관리한다.
        여기 lang_english 는 앱 테마(themes.xml)의 colorPrimary/colorAccent 로만 쓰인다.
        (미사용이던 lang_korean/lang_default/badge_bg/badge_text/ui_divider 는 정리로 제거)
    -->
    <color name="lang_english">#1A6EBD</color>

    <!-- 칩("교체?") 배경/글씨 (bg_chip.xml, ReplaceChipView 사용) -->
    <color name="chip_bg">#1C1C1E</color>
    <color name="chip_text">#FFFFFFFF</color>

    <color name="ic_launcher_background">#1A6EBD</color>

    <!-- UI 강조색(섹션 헤더/타이틀) — 살짝 세련된 느낌의 공용 액센트 -->
    <color name="ui_accent">#2E7DD1</color>
    <!-- 온보딩 구분선/보조 텍스트 (하드코딩 헥스 대신 공용 참조로 통일) -->
    <color name="ui_divider">#33808080</color>
    <color name="ui_muted">#888888</color>
    <!-- 상태 배지 색 -->
    <color name="status_ok">#2D8C4E</color>
    <color name="status_need">#CC2D2D</color>
</resources>
