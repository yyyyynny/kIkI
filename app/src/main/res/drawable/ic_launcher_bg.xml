<?xml version="1.0" encoding="utf-8"?>
<!--
    적응형 아이콘 배경 — 「심연 + 발광 유리 칩」(design/reference 참고).
    딥 네이비 심연 위로 두 언어의 빛이 **화면 전체에 넓게** 스며든다:
    좌하단 웜(저채도 코랄) + 우상단 쿨(저채도 블루). 진한 원색·경계선 없음 —
    "전환은 한 점의 깜빡임이 아니라 화면 전체에 넓게 퍼진다"는 피드백 반영.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- 심연 네이비 베이스 -->
    <path android:pathData="M0,0 H108 V108 H0 Z" android:fillColor="#0A182D" />
    <!-- 우상단에서 넓게 스미는 쿨(영어) 빛 -->
    <path android:pathData="M0,0 H108 V108 H0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="86" android:centerY="18"
                android:gradientRadius="104"
                android:startColor="#8C5C88C0"
                android:endColor="#005C88C0" />
        </aapt:attr>
    </path>
    <!-- 좌하단에서 넓게 스미는 웜(한국어) 빛 -->
    <path android:pathData="M0,0 H108 V108 H0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="20" android:centerY="92"
                android:gradientRadius="102"
                android:startColor="#80C08072"
                android:endColor="#00C08072" />
        </aapt:attr>
    </path>
</vector>
